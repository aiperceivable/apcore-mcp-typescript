{
  "name": "apcore-mcp",
  "version": "0.10.0",
  "description": "Automatic MCP Server & OpenAI Tools Bridge for apcore",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "apcore-mcp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "apcore",
    "mcp",
    "model-context-protocol",
    "openai",
    "tools",
    "function-calling",
    "ai-agent",
    "mcp-server",
    "tool-bridge",
    "agent-tools",
    "schema",
    "json-schema",
    "validation",
    "router",
    "transport",
    "cli"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "apcore-js": "^0.13.0",
    "jsonwebtoken": "^9.0.3",
    "mcp-embedded-ui": "^0.3.0"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "apdev-js": "^0.2.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "apdev": {
    "base_package": "apcore-mcp"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aipartnerup/apcore-mcp-typescript.git"
  },
  "homepage": "https://github.com/aipartnerup",
  "bugs": {
    "url": "https://github.com/aipartnerup/apcore-mcp-typescript/issues"
  }
}